<% const title = locals.title || 'Welcome — Set up Ngulube Hub'; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
  <style>
    body {
      background: linear-gradient(160deg, #1F2D5C 0%, #2c3f7a 60%, #1F2D5C 100%);
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      padding: 24px 16px; margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", Roboto, sans-serif;
    }
    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image:
        radial-gradient(circle at 20% 30%, rgba(242, 107, 74, 0.08) 0%, transparent 50%),
        radial-gradient(circle at 80% 70%, rgba(255, 255, 255, 0.04) 0%, transparent 50%);
      pointer-events: none;
    }
    .auth-shell { position: relative; z-index: 1; max-width: 460px; width: 100%; }
    .auth-card {
      background: #ffffff;
      border-radius: 16px;
      padding: 36px 32px 28px;
      box-shadow: 0 25px 50px rgba(0,0,0,0.25);
    }
    .auth-card .brand {
      display: flex; align-items: center; justify-content: center; gap: 10px;
      margin-bottom: 6px;
    }
    .auth-card .brand img { width: 28px; height: 28px; }
    .auth-card .brand .word { font-size: 16px; font-weight: 700; color: var(--brand); }
    .auth-card h1 {
      font-size: 22px; font-weight: 600;
      text-align: center;
      margin: 22px 0 6px;
      color: var(--text);
    }
    .auth-card .sub {
      text-align: center;
      color: var(--text-2);
      font-size: 13px;
      margin: 0 0 22px;
      line-height: 1.5;
    }
    .auth-card .info {
      background: #fef9c3;
      color: #854d0e;
      border: 1px solid #fde68a;
      border-radius: 8px;
      padding: 10px 12px;
      font-size: 12.5px;
      margin-bottom: 18px;
      line-height: 1.5;
    }
    .auth-card .err {
      background: var(--red-bg); color: #991b1b;
      border: 1px solid #fca5a5;
      border-radius: 8px;
      padding: 10px 12px;
      font-size: 13px;
      margin-bottom: 16px;
    }
    .auth-card .field { margin-bottom: 14px; }
    .auth-card label {
      display: block;
      font-size: 12px;
      color: var(--text-2);
      margin-bottom: 6px;
      font-weight: 500;
    }
    .auth-card input {
      width: 100%;
      padding: 11px 14px;
      height: 44px;
      border: 1.5px solid var(--border-strong);
      border-radius: 8px;
      font-size: 14px;
      color: var(--text);
      background: var(--bg);
      outline: none;
      transition: border-color 0.12s, box-shadow 0.12s, background 0.12s;
    }
    .auth-card input::placeholder { color: var(--text-3); }
    .auth-card input:focus {
      border-color: var(--accent);
      background: #fff;
      box-shadow: 0 0 0 3px var(--accent-glow);
    }
    .auth-card .btn-primary {
      width: 100%;
      height: 44px;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 8px;
      display: flex; align-items: center; justify-content: center; gap: 6px;
      transition: background 0.15s, transform 0.05s, box-shadow 0.15s;
    }
    .auth-card .btn-primary:hover {
      background: var(--accent-hover);
      box-shadow: 0 6px 20px var(--accent-glow);
    }
    .auth-card .btn-primary:active { transform: translateY(1px); }
    .auth-card .footer {
      margin-top: 22px; padding-top: 14px;
      border-top: 1px solid var(--border);
      font-size: 11px;
      color: var(--text-3);
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="auth-shell">
    <div class="auth-card">
      <div class="brand">
        <img src="/img/logo-pig.svg" alt="">
        <span class="word">NgulubeHub</span>
      </div>
      <h1>Welcome to Ngulube Hub</h1>
      <p class="sub">No admin account exists yet. Create the first super-admin to get started. This account can add other admins later.</p>

      <div class="info">
        <i class="bi bi-info-circle"></i> <strong>One-time setup.</strong> Once created, you can add more admins from the Admin → Users page.
      </div>

      <% if (error) { %><div class="err"><i class="bi bi-exclamation-triangle"></i> <%= error %></div><% } %>

      <form method="post" action="/setup">
        <div class="field">
          <label>Your name</label>
          <input name="name" required autofocus placeholder="e.g. Thabiso">
        </div>
        <div class="field">
          <label>Username</label>
          <input name="username" required minlength="3" maxlength="30" placeholder="lowercase, no spaces">
        </div>
        <div class="field">
          <label>Password (min 6 chars)</label>
          <input name="password" type="password" required minlength="6" placeholder="Pick a strong one">
        </div>
        <button type="submit" class="btn-primary"><i class="bi bi-rocket-takeoff"></i> Create super-admin & sign in</button>
      </form>

      <div class="footer">
        © <%= new Date().getFullYear() %> Ngulube Hub
      </div>
    </div>
  </div>
</body>
</html>
