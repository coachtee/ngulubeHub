<% const title = locals.title || 'Sign in — Ngulube Hub'; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
  <style>
    body {
      background: linear-gradient(135deg, #1F2D5C 0%, #2c3f7a 100%);
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      margin: 0; padding: 24px 16px;
      font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", Roboto, sans-serif;
    }
    .auth-card {
      background: #fff; border-radius: 14px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.25);
      padding: 36px 32px; max-width: 420px; width: 100%;
    }
    .auth-card .brand { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; }
    /* The logo SVG uses currentColor for the snout; we set color: #F26B4A so the
       snout pops on the white card and the navy face/ears sit nicely. */
    .auth-card .brand img { width: 44px; height: 44px; color: #F26B4A; }
    .auth-card .brand .t h1 { font-size: 22px; font-weight: 700; margin: 0; color: var(--brand); }
    .auth-card .brand .t p { font-size: 13px; color: var(--text-2); margin: 0; }
    .auth-card .err { background: var(--red-bg); color: var(--red); border-radius: 6px; padding: 10px 12px; font-size: 13px; margin-bottom: 14px; }
    .auth-card .ok { background: var(--green-bg); color: var(--green); border-radius: 6px; padding: 10px 12px; font-size: 13px; margin-bottom: 14px; }
    .auth-card label { display: block; font-size: 12px; color: var(--text-2); margin-bottom: 4px; font-weight: 500; }
    .auth-card input {
      width: 100%; padding: 9px 12px; height: 40px;
      border: 1px solid var(--border-strong); border-radius: 6px;
      font-size: 14px; color: var(--text);
      outline: none; transition: border-color 0.12s;
    }
    .auth-card input:focus { border-color: var(--brand); }
    .auth-card .form-group { margin-bottom: 14px; }
    .auth-card .btn-primary {
      background: var(--brand); color: #fff; border: none;
      width: 100%; padding: 11px; font-size: 14px; font-weight: 500;
      border-radius: 6px; cursor: pointer; margin-top: 6px;
    }
    .auth-card .btn-primary:hover { background: var(--brand-2); }
    .auth-card .alt {
      text-align: center; margin-top: 18px;
      font-size: 12.5px; color: var(--text-2);
    }
    .auth-card .alt a { color: var(--brand); }
    .auth-card .footer {
      margin-top: 24px; padding-top: 16px;
      border-top: 1px solid var(--border);
      font-size: 11px; color: var(--text-3); text-align: center;
    }
  </style>
</head>
<body>
  <div class="auth-card">
    <div class="brand">
      <img src="/img/logo-pig.svg" alt="Ngulube Hub">
      <div class="t">
        <h1>Ngulube Hub</h1>
        <p><%= typeof subtitle !== 'undefined' ? subtitle : 'Sign in to continue' %></p>
      </div>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="err"><i class="bi bi-exclamation-circle"></i> <%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="ok"><i class="bi bi-check-circle"></i> <%= success %></div>
    <% } %>

    <form method="POST" action="/login">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" autocomplete="username" required>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" autocomplete="current-password" required>
      </div>
      <button type="submit" class="btn-primary">Sign in</button>
    </form>

    <div class="alt">
      Don't have access? <a href="/join">Join the network</a> · <a href="/setup">First-time setup</a>
    </div>

    <div class="footer">
      © <%= new Date().getFullYear() %> Ngulube Hub · <a href="https://github.com/coachtee/ngulubeHub" style="color: var(--text-3);">MIT</a>
    </div>
  </div>
</body>
</html>
