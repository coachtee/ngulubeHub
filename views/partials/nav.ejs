<div class="app-shell">
  <aside class="sidebar">
    <div class="brand">
      <img src="/img/logo.svg" alt="Ngulube Hub" class="brand-logo">
      <span>Ngulube Hub</span>
    </div>

    <nav class="nav">
      <a class="nav-item <%= typeof active !== 'undefined' && active === 'dashboard' ? 'active' : '' %>" href="/">
        <i class="bi bi-grid-1x2"></i> Dashboard
      </a>
      <a class="nav-item <%= typeof active !== 'undefined' && active === 'add' ? 'active' : '' %>" href="/clients/new">
        <i class="bi bi-person-plus"></i> Add Client
      </a>
      <a class="nav-item <%= typeof active !== 'undefined' && active === 'catalog' ? 'active' : '' %>" href="/catalog">
        <i class="bi bi-stars"></i> AI Solutions
      </a>

      <div class="nav-section">Pipeline</div>
      <a class="nav-item" href="/?status=Not+contacted">
        <i class="bi bi-hourglass-split"></i> Not Contacted
      </a>
      <a class="nav-item" href="/?status=Intro+sent">
        <i class="bi bi-send"></i> Intro Sent
      </a>
      <a class="nav-item" href="/?status=Engaged">
        <i class="bi bi-handshake"></i> Engaged / Won
      </a>

      <% if (currentUser && currentUser.role === 'superadmin') { %>
        <div class="nav-section">Admin</div>
        <a class="nav-item <%= typeof active !== 'undefined' && active === 'admin' ? 'active' : '' %>" href="/admin/users">
          <i class="bi bi-shield-lock"></i> Manage Admins
        </a>
      <% } %>
    </nav>

    <% if (currentUser) { %>
      <div class="user-box">
        <div class="avatar"><%= (currentUser.name || currentUser.username).charAt(0).toUpperCase() %></div>
        <div class="meta">
          <div class="name"><%= currentUser.name || currentUser.username %></div>
          <div class="role"><%= currentUser.role === 'superadmin' ? 'Super-admin' : 'Admin' %></div>
        </div>
        <form method="post" action="/logout" style="margin-left: auto;">
          <button class="btn sm ghost" style="color: rgba(255,255,255,0.7); padding: 4px 8px;" title="Sign out"><i class="bi bi-box-arrow-right"></i></button>
        </form>
      </div>
    <% } %>
  </aside>

  <div class="main">
    <div class="topbar">
      <div class="greeting">
        Hello <span class="wave">👋</span>
        <% if (currentUser) { %><span style="color: var(--text-2); font-weight: 500; font-size: 14px;">, <%= currentUser.name || currentUser.username %></span><% } %>
      </div>
      <form class="search" method="get" action="/">
        <i class="bi bi-search"></i>
        <input type="search" name="q" placeholder="Search clients, tags, focus areas…" value="<%= typeof q !== 'undefined' ? q : '' %>">
      </form>
      <a href="/clients/new" class="btn primary"><i class="bi bi-plus-lg"></i> Add Client</a>
    </div>
    <div class="content">
