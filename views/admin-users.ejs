<% const title = locals.title || 'Admin Users — Ngulube Hub'; const active = 'admin'; %>
<%- include('partials/head', { title, active }) %>
<div class="app-shell">
<%- include('partials/nav') %>
<main class="main">
<%- include('partials/topbar') %>
<div class="content">

  <header class="d-flex flex-wrap justify-between items-center mb-3">
    <div>
      <h1 style="font-size: 22px; font-weight: 700; margin: 0;"><i class="bi bi-shield-lock"></i> Admin Users</h1>
      <p class="text-muted mb-0" style="font-size: 13px; margin-top: 2px;">Manage who can sign in to Ngulube Hub.</p>
    </div>
  </header>

  <% if (typeof flash !== 'undefined' && flash) { %>
    <div class="alert <%= flash.type === 'error' ? 'alert-danger' : 'alert-success' %>" style="border-radius: 6px; padding: 10px 14px; font-size: 13px; margin-bottom: 16px;">
      <i class="bi bi-<%= flash.type === 'error' ? 'exclamation-triangle' : 'check-circle' %>"></i> <%= flash.message %>
    </div>
  <% } %>

  <div style="display: grid; grid-template-columns: 1fr 360px; gap: 16px;">
    <!-- USERS LIST -->
    <div class="table-card">
      <div class="table-toolbar">
        <span class="selection-info"><strong><%= allUsers.length %></strong> admin<%= allUsers.length === 1 ? '' : 's' %></span>
      </div>
      <table class="t">
        <thead>
          <tr>
            <th>User</th>
            <th>Role</th>
            <th>Last login</th>
            <th>Created</th>
            <th style="text-align: right; padding-right: 16px;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% allUsers.forEach(u => {
            const initials = (u.name || u.username).split(' ').slice(0,2).map(w => w[0]).join('').toUpperCase();
          %>
            <tr>
              <td>
                <div class="avatar-row">
                  <div class="avatar"><%= initials %></div>
                  <div class="meta">
                    <div class="n"><%= u.name || u.username %></div>
                    <div class="s">@<%= u.username %></div>
                  </div>
                </div>
              </td>
              <td>
                <% if (u.role === 'superadmin') { %>
                  <span class="pill blue"><span class="dot"></span> Super-admin</span>
                <% } else { %>
                  <span class="pill gray"><span class="dot"></span> Admin</span>
                <% } %>
              </td>
              <td class="mono"><%= u.last_login_at ? u.last_login_at.slice(0, 16).replace('T', ' ') : '—' %></td>
              <td class="mono"><%= u.created_at ? u.created_at.slice(0, 10) : '—' %></td>
              <td>
                <div class="row-actions">
                  <button class="btn sm ghost" onclick="togglePwForm(<%= u.id %>)" title="Reset password"><i class="bi bi-key"></i></button>
                  <% if (u.id !== currentUser.id) { %>
                    <form method="post" action="/admin/users/<%= u.id %>/delete" style="display: inline;" onsubmit="return confirm('Remove admin <%= u.name || u.username %>?')">
                      <button class="btn sm ghost" style="color: var(--red);" title="Delete"><i class="bi bi-trash"></i></button>
                    </form>
                  <% } else { %>
                    <span class="text-muted" style="font-size: 11px;">(you)</span>
                  <% } %>
                </div>
              </td>
            </tr>
            <tr id="pw-row-<%= u.id %>" style="display: none; background: #fffbeb;">
              <td colspan="5" style="padding: 14px 16px;">
                <form method="post" action="/admin/users/<%= u.id %>/password" class="d-flex items-center gap-2">
                  <input type="password" name="new_password" required minlength="6" placeholder="New password (min 6 chars)" class="form-control" style="max-width: 280px;">
                  <button class="btn primary sm"><i class="bi bi-check-lg"></i> Update password</button>
                  <button type="button" class="btn ghost sm" onclick="togglePwForm(<%= u.id %>)">Cancel</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- ADD ADMIN FORM -->
    <div class="panel">
      <div class="panel-head"><i class="bi bi-person-plus"></i> Add admin</div>
      <div class="panel-body">
        <form method="post" action="/admin/users">
          <div class="form-group mb-2">
            <label>Full name</label>
            <input name="name" required placeholder="e.g. Hulisani">
          </div>
          <div class="form-group mb-2">
            <label>Username</label>
            <input name="username" required pattern="[a-zA-Z0-9_-]{3,30}" placeholder="lowercase, no spaces">
          </div>
          <div class="form-group mb-2">
            <label>Password (min 6 chars)</label>
            <input name="password" type="password" required minlength="6">
          </div>
          <div class="form-group mb-2">
            <label>Role</label>
            <select name="role">
              <option value="admin">Admin (read/write data)</option>
              <option value="superadmin">Super-admin (can add/remove admins)</option>
            </select>
          </div>
          <button class="btn primary" style="width: 100%;"><i class="bi bi-plus-lg"></i> Add admin</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    function togglePwForm(id) {
      const row = document.getElementById('pw-row-' + id);
      if (row) row.style.display = row.style.display === 'none' ? 'table-row' : 'none';
    }
  </script>

</div>
</main>
</div>
<%- include('partials/foot') %>
