<% const title = 'Edit ' + provider.name + ' — Ngulube Hub'; const active = 'admin'; %>
<%- include('partials/head', { title, active }) %>
<div class="app-shell">
<%- include('partials/nav') %>
<main class="main">
<%- include('partials/topbar') %>
<div class="content">

  <a href="/admin/providers" class="text-muted" style="font-size: 12px;"><i class="bi bi-arrow-left"></i> Back to AI Providers</a>
  <h1 class="cu-page-title" style="margin: 6px 0 18px;"><i class="bi bi-pencil"></i> Edit <%= provider.name %></h1>

  <% if (typeof flash !== 'undefined' && flash) { %>
    <div class="alert <%= flash.type === 'error' ? 'alert-danger' : 'alert-success' %>" style="border-radius: 6px; padding: 10px 14px; font-size: 13px; margin-bottom: 16px;">
      <i class="bi bi-<%= flash.type === 'error' ? 'exclamation-triangle' : 'check-circle' %>"></i> <%= flash.message %>
    </div>
  <% } %>

  <div style="max-width: 600px;">
    <div class="panel">
      <div class="panel-body">
        <form method="post" action="/admin/providers/<%= provider.id %>/edit">
          <div class="form-group mb-3">
            <label>Display name</label>
            <input name="name" required value="<%= provider.name %>">
          </div>
          <div class="form-group mb-3">
            <label>Kind</label>
            <select name="kind">
              <% kinds.forEach(k => { %>
                <option value="<%= k.kind %>" <%= provider.kind === k.kind ? 'selected' : '' %>><%= k.label %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group mb-3">
            <label>API key</label>
            <input name="api_key" type="password" placeholder="(unchanged)" value="" autocomplete="off">
            <small class="text-muted" style="font-size: 11.5px;">Leave blank to keep the existing key.</small>
          </div>
          <div class="form-group mb-3">
            <label>Base URL</label>
            <input name="base_url" value="<%= provider.base_url || '' %>" placeholder="https://api.openai.com/v1">
          </div>
          <div class="form-group mb-3">
            <label>Model</label>
            <input name="model" required value="<%= provider.model || '' %>">
          </div>
          <div class="form-group mb-3">
            <label>Priority <small class="text-muted">(lower = tried first)</small></label>
            <input name="priority" type="number" value="<%= provider.priority %>" min="1" max="9999">
          </div>
          <div class="form-group mb-3">
            <label>
              <input type="checkbox" name="is_default" value="1" <%= provider.is_default ? 'checked' : '' %>> Set as default
            </label>
            <label style="margin-left: 16px;">
              <input type="checkbox" name="enabled" value="1" <%= provider.enabled ? 'checked' : '' %>> Enabled
            </label>
          </div>
          <div class="form-group mb-3">
            <label>Notes</label>
            <textarea name="notes" rows="2"><%= provider.notes || '' %></textarea>
          </div>
          <div class="d-flex gap-2">
            <button class="btn primary" type="submit"><i class="bi bi-check-lg"></i> Save changes</button>
            <a class="btn ghost" href="/admin/providers">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>

</div>
</main>
</div>
<%- include('partials/foot') %>
