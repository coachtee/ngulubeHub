<% const title = 'Join the Ngulube Hub Network'; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
  <style>
    body {
      background: linear-gradient(135deg, #1F2D5C 0%, #2c3f7a 100%);
      min-height: 100vh;
      margin: 0; padding: 24px 16px;
      font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", Roboto, sans-serif;
    }
    .join-shell { max-width: 720px; margin: 0 auto; }
    .join-card {
      background: #fff; border-radius: 14px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.25);
      overflow: hidden;
    }
    .join-hero {
      background: linear-gradient(135deg, #F26B4A 0%, #d85535 100%);
      color: #fff;
      padding: 36px 36px 30px;
    }
    .join-hero .brand { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
    .join-hero .brand img { width: 40px; height: 40px; }
    .join-hero h1 { font-size: 26px; font-weight: 700; margin: 0; }
    .join-hero p { font-size: 14px; opacity: 0.95; margin: 8px 0 0; line-height: 1.5; }
    .join-form { padding: 32px 36px; }
    .join-form .row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px 18px; }
    .join-form .row .full { grid-column: 1 / -1; }
    .join-form label { display: block; font-size: 12px; color: var(--text-2); margin-bottom: 4px; font-weight: 500; }
    .join-form label .req { color: var(--red); }
    .join-form input, .join-form select, .join-form textarea {
      width: 100%; padding: 9px 12px; height: 40px;
      border: 1px solid var(--border-strong); border-radius: 6px;
      font-size: 14px; color: var(--text);
      outline: none; transition: border-color 0.12s;
      font-family: inherit;
    }
    .join-form textarea { height: auto; min-height: 80px; padding: 10px 12px; resize: vertical; }
    .join-form input:focus, .join-form select:focus, .join-form textarea:focus { border-color: var(--brand); }
    .join-form .field { margin-bottom: 14px; }
    .join-form .help { font-size: 11.5px; color: var(--text-3); margin-top: 4px; }
    .join-form .submit { margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; }
    .join-form .submit .meta { font-size: 12px; color: var(--text-3); }
    .btn-submit {
      background: var(--brand); color: #fff; border: none;
      padding: 11px 24px; font-size: 14px; font-weight: 500;
      border-radius: 6px; cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px;
    }
    .btn-submit:hover { background: var(--brand-2); }
    .join-form .privacy { font-size: 11.5px; color: var(--text-3); line-height: 1.5; }
    .join-form .privacy a { color: var(--brand); }
    .ok-banner { background: #dcfce7; color: #166534; border-radius: 8px; padding: 14px 18px; margin: 16px 36px 0; font-size: 13.5px; }
    .ok-banner i { margin-right: 6px; }
    .err-banner { background: #fee2e2; color: #991b1b; border-radius: 8px; padding: 14px 18px; margin: 16px 36px 0; font-size: 13.5px; }
    .footer { text-align: center; color: rgba(255,255,255,0.7); font-size: 11px; margin-top: 24px; padding-bottom: 20px; }
    @media (max-width: 600px) {
      .join-hero { padding: 28px 22px; }
      .join-form { padding: 24px 22px; }
      .join-form .row { grid-template-columns: 1fr; }
      .join-hero h1 { font-size: 22px; }
    }
  </style>
</head>
<body>
  <div class="join-shell">
    <div class="join-card">
      <div class="join-hero">
        <div class="brand">
          <img src="/img/logo-pig.svg" alt="Ngulube Hub" style="color: #fff;">
          <div>
            <div style="font-weight: 600; font-size: 13px; opacity: 0.85;">Ngulube Hub</div>
            <div style="font-size: 11px; opacity: 0.7;">Network &middot; Curated connections &middot; AI solutions</div>
          </div>
        </div>
        <h1>Join the network</h1>
        <p>Tell us a bit about what you do. If there's a fit, we'll be in touch within a few days to set up a quick intro.</p>
      </div>

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="ok-banner">
          <i class="bi bi-check-circle-fill"></i>
          <strong>You're in.</strong> We received your details and a Ngulube Hub admin will review them shortly. We'll WhatsApp or email you with a personal intro.
        </div>
        <div class="join-form" style="padding-top: 24px;">
          <p style="text-align: center; color: var(--text-2); font-size: 14px;">Want to refer someone who'd be a great fit?</p>
          <p style="text-align: center;"><a href="/join" class="btn-submit" style="background: var(--accent);">Submit another person</a></p>
        </div>
      <% } else { %>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="err-banner"><i class="bi bi-exclamation-triangle"></i> <%= error %></div>
        <% } %>

        <form class="join-form" method="POST" action="/join">
          <div class="row">
            <div class="field">
              <label>Your full name <span class="req">*</span></label>
              <input name="name" required maxlength="120" placeholder="e.g. Sipho Dlamini">
            </div>
            <div class="field">
              <label>WhatsApp / Mobile <span class="req">*</span></label>
              <input name="phone" required maxlength="40" placeholder="076 123 4567">
            </div>

            <div class="field">
              <label>Email <span class="req">*</span></label>
              <input type="email" name="email" required maxlength="180" placeholder="you@example.com">
            </div>
            <div class="field">
              <label>Company / Project <span class="req">*</span></label>
              <input name="company" required maxlength="160" placeholder="What you call your work">
            </div>

            <div class="field">
              <label>Sector <span class="req">*</span></label>
              <select name="sector" required>
                <option value="">Pick one…</option>
                <option>Agriculture & Food</option>
                <option>Mining & Resources</option>
                <option>Manufacturing</option>
                <option>Retail & E-commerce</option>
                <option>Financial Services</option>
                <option>Professional Services</option>
                <option>Health & Wellness</option>
                <option>Education & Training</option>
                <option>Property & Real Estate</option>
                <option>Tourism & Hospitality</option>
                <option>Tech & SaaS</option>
                <option>Logistics & Transport</option>
                <option>Creative & Media</option>
                <option>NGO & Development</option>
                <option>Government & Public Sector</option>
                <option>Other</option>
              </select>
            </div>
            <div class="field">
              <label>Industry <span class="req">*</span></label>
              <input name="industry" required maxlength="80" placeholder="e.g. Fintech, Solar, FMCG…">
            </div>

            <div class="field full">
              <label>One line: what do you do? <span class="req">*</span></label>
              <input name="bio" required maxlength="240" placeholder="We help SMEs in Limpopo do X for Y.">
            </div>

            <div class="field full">
              <label>Who's your ideal client or partner? <span class="req">*</span></label>
              <textarea name="ideal_client" required maxlength="600" placeholder="Be specific. e.g. 'Mining suppliers with 10–50 staff in Limpopo who need procurement automation'."></textarea>
              <div class="help">The more specific, the better the intros we can set up.</div>
            </div>

            <div class="field">
              <label>LinkedIn / website (optional)</label>
              <input name="url" type="url" maxlength="240" placeholder="https://…">
            </div>
            <div class="field">
              <label>How did you hear about us? (optional)</label>
              <input name="referrer" maxlength="120" placeholder="e.g. WhatsApp group, referred by…">
            </div>
          </div>

          <div class="submit">
            <div class="meta">
              <div>Already a member? <a href="/login">Sign in</a></div>
            </div>
            <button type="submit" class="btn-submit">
              <i class="bi bi-send"></i> Submit
            </button>
          </div>

          <div class="privacy" style="margin-top: 18px;">
            By submitting, you agree we may store your details in our private network database and reach out via WhatsApp or email.
            We don't share or sell your data.
            See <a href="/privacy" target="_blank" rel="noopener">privacy</a> for the full policy.
          </div>
        </form>
      <% } %>
    </div>
    <div class="footer">
      © <%= new Date().getFullYear() %> Ngulube Hub · A private network for builders in South Africa
    </div>
  </div>
</body>
</html>
