<% const title = 'Join the Ngulube Hub Network'; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
  <style>
    body {
      align-items: flex-start;
      background: var(--bg);
      padding: 32px 16px;
    }
    .join-shell { max-width: 720px; margin: 24px auto; position: relative; z-index: 1; }
    .join-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: var(--shadow-md);
    }
    .join-hero {
      background: linear-gradient(135deg, var(--brand) 0%, var(--brand-2) 100%);
      border-bottom: 1px solid var(--border);
      padding: 32px 36px 24px;
      color: #fff;
    }
    .join-hero .brand { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
    .join-hero .brand .word {
      font-weight: 800; font-size: 16px; color: #fff;
      letter-spacing: -0.02em;
    }
    .join-hero h1 { font-size: 26px; font-weight: 700; margin: 0; color: #fff; }
    .join-hero p { font-size: 14px; color: rgba(255,255,255,0.85); margin: 8px 0 0; line-height: 1.5; }
    .join-form { padding: 28px 36px 24px; }
    .join-form .row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px 18px; }
    .join-form .row .full { grid-column: 1 / -1; }
    .join-form label { display: block; font-size: 12px; color: var(--text-2); margin-bottom: 6px; font-weight: 500; }
    .join-form label .req { color: var(--red); }
    .join-form input, .join-form select, .join-form textarea {
      width: 100%; padding: 11px 14px; height: 44px;
      background: var(--surface);
      border: 1px solid var(--border-strong);
      border-radius: 8px;
      font-size: 14px; color: var(--text);
      outline: none; transition: border-color 0.12s, box-shadow 0.12s;
      font-family: inherit;
    }
    .join-form textarea { height: auto; min-height: 80px; padding: 10px 14px; resize: vertical; }
    .join-form input::placeholder, .join-form textarea::placeholder { color: var(--text-3); }
    .join-form input:focus, .join-form select:focus, .join-form textarea:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }
    .join-form .field { margin-bottom: 14px; }
    .join-form .help { font-size: 11.5px; color: var(--text-3); margin-top: 4px; }
    .join-form .submit {
      margin-top: 24px; padding-top: 20px;
      border-top: 1px solid var(--border);
      display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap;
    }
    .join-form .submit .meta { font-size: 12px; color: var(--text-2); }
    .join-form .submit .meta a { color: var(--accent); }
    .btn-submit {
      background: var(--accent); color: #fff; border: none;
      padding: 11px 24px; font-size: 14px; font-weight: 600;
      border-radius: 8px; cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px;
      transition: background 0.15s, transform 0.05s, box-shadow 0.15s;
    }
    .btn-submit:hover { background: var(--accent-hover); box-shadow: 0 6px 20px var(--accent-glow); }
    .btn-submit:active { transform: translateY(1px); }
    .join-form .privacy { font-size: 11.5px; color: var(--text-3); line-height: 1.5; margin-top: 18px; }
    .join-form .privacy a { color: var(--accent); }
    .ok-banner {
      background: var(--green-bg); color: #166534;
      border: 1px solid #86efac;
      border-radius: 8px; padding: 14px 18px;
      margin: 16px 36px 0; font-size: 13.5px;
    }
    .ok-banner strong { color: #15803d; }
    .err-banner {
      background: var(--red-bg); color: #991b1b;
      border: 1px solid #fca5a5;
      border-radius: 8px; padding: 14px 18px;
      margin: 16px 36px 0; font-size: 13.5px;
    }
    .footer { text-align: center; color: var(--text-3); font-size: 11px; margin-top: 18px; padding-bottom: 20px; }
    @media (max-width: 600px) {
      .join-hero { padding: 24px 22px; }
      .join-form { padding: 20px 22px; }
      .join-form .row { grid-template-columns: 1fr; }
      .join-hero h1 { font-size: 22px; }
      .ok-banner, .err-banner { margin: 12px 22px 0; }
    }
  </style>
</head>
<body>
  <div class="join-shell">
    <div class="join-card">
      <div class="join-hero">
        <div class="brand">
          <span class="word">NgulubeHub</span>
        </div>
        <h1>Join the network</h1>
        <p>Tell us a bit about what you do. If there's a fit, we'll be in touch within a few days to set up a quick intro.</p>
      </div>

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="ok-banner">
          <i class="bi bi-check-circle-fill"></i>
          <strong>You're in.</strong> We received your details and a Ngulube Hub admin will review them shortly. We'll WhatsApp or email you with a personal intro.
        </div>
        <div class="join-form" style="padding-top: 24px;">
          <p style="text-align: center; color: var(--text-2); font-size: 14px;">Want to refer someone who'd be a great fit?</p>
          <p style="text-align: center;"><a href="/join" class="btn-submit">Submit another person</a></p>
        </div>
      <% } else { %>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="err-banner"><i class="bi bi-exclamation-triangle"></i> <%= error %></div>
        <% } %>

        <form class="join-form" method="POST" action="/join">
          <div class="row">
            <div class="field">
              <label>Your full name <span class="req">*</span></label>
              <input name="name" required maxlength="120" placeholder="e.g. Sipho Dlamini">
            </div>
            <div class="field">
              <label>WhatsApp / Mobile <span class="req">*</span></label>
              <input name="phone" required maxlength="40" placeholder="076 123 4567">
            </div>

            <div class="field">
              <label>Email <span class="req">*</span></label>
              <input type="email" name="email" required maxlength="180" placeholder="you@example.com">
            </div>
            <div class="field">
              <label>Company / Project <span class="req">*</span></label>
              <input name="company" required maxlength="160" placeholder="What you call your work">
            </div>

            <div class="field">
              <label>Sector <span class="req">*</span></label>
              <select name="sector" required>
                <option value="">Pick one…</option>
                <option>Agriculture & Food</option>
                <option>Mining & Resources</option>
                <option>Manufacturing</option>
                <option>Retail & E-commerce</option>
                <option>Financial Services</option>
                <option>Professional Services</option>
                <option>Health & Wellness</option>
                <option>Education & Training</option>
                <option>Property & Real Estate</option>
                <option>Tourism & Hospitality</option>
                <option>Tech & SaaS</option>
                <option>Logistics & Transport</option>
                <option>Creative & Media</option>
                <option>NGO & Development</option>
                <option>Government & Public Sector</option>
                <option>Other</option>
              </select>
            </div>
            <div class="field">
              <label>Industry <span class="req">*</span></label>
              <input name="industry" required maxlength="80" placeholder="e.g. Fintech, Solar, FMCG…">
            </div>

            <div class="field full">
              <label>One line: what do you do? <span class="req">*</span></label>
              <input name="bio" required maxlength="240" placeholder="We help SMEs in Limpopo do X for Y.">
            </div>

            <div class="field full">
              <label>Who's your ideal client or partner? <span class="req">*</span></label>
              <textarea name="ideal_client" required maxlength="600" placeholder="Be specific. e.g. 'Mining suppliers with 10–50 staff in Limpopo who need procurement automation'."></textarea>
              <div class="help">The more specific, the better the intros we can set up.</div>
            </div>

            <div class="field">
              <label>LinkedIn / website (optional)</label>
              <input name="url" type="url" maxlength="240" placeholder="https://…">
            </div>
            <div class="field">
              <label>How did you hear about us? (optional)</label>
              <input name="referrer" maxlength="120" placeholder="e.g. WhatsApp group, referred by…">
            </div>
          </div>

          <div class="submit">
            <div class="meta">
              <div>Already a member? <a href="/login">Sign in</a></div>
            </div>
            <button type="submit" class="btn-submit">
              <i class="bi bi-send"></i> Submit
            </button>
          </div>

          <div class="privacy">
            By submitting, you agree we may store your details in our private network database and reach out via WhatsApp or email.
            We don't share or sell your data.
          </div>
        </form>
      <% } %>
    </div>
    <div class="footer">
      © <%= new Date().getFullYear() %> Ngulube Hub · A private network for builders in South Africa
    </div>
  </div>
</body>
</html>
