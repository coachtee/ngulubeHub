<% const title = 'AI Providers — Ngulube Hub'; const active = 'admin'; %>
<%- include('partials/head', { title, active }) %>
<div class="app-shell">
<%- include('partials/nav') %>
<main class="main">
<%- include('partials/topbar') %>
<div class="content">

  <a href="/admin/users" class="text-muted" style="font-size: 12px;"><i class="bi bi-arrow-left"></i> Back to Admin</a>
  <h1 class="cu-page-title" style="margin: 6px 0 4px;"><i class="bi bi-cpu"></i> AI Providers</h1>
  <p class="cu-page-sub">Configure which AI services power features like Meeting Prep, Follow-up Writer, and Intro Briefs.</p>

  <% if (typeof flash !== 'undefined' && flash) { %>
    <div class="alert <%= flash.type === 'error' ? 'alert-danger' : 'alert-success' %>" style="border-radius: 6px; padding: 10px 14px; font-size: 13px; margin-bottom: 16px;">
      <i class="bi bi-<%= flash.type === 'error' ? 'exclamation-triangle' : 'check-circle' %>"></i> <%= flash.message %>
    </div>
  <% } %>

  <div class="row" style="display: grid; grid-template-columns: 1fr 380px; gap: 16px; align-items: start;">
    <div>
      <% if (!providers.length) { %>
        <div class="panel">
          <div class="panel-body" style="padding: 40px 24px; text-align: center;">
            <i class="bi bi-cpu" style="font-size: 36px; color: var(--text-3); opacity: 0.4;"></i>
            <h3 style="margin: 12px 0 4px; font-size: 16px; color: var(--text);">No AI providers configured</h3>
            <p class="text-muted mb-0" style="font-size: 13px;">Add one on the right to unlock Meeting Prep and AI-enhanced features.</p>
          </div>
        </div>
      <% } %>

      <% providers.forEach(p => { %>
        <div class="panel" style="margin-bottom: 12px;">
          <div class="panel-head">
            <i class="bi bi-<%= p.kind === 'openai' ? 'openai-logo' : p.kind === 'anthropic' ? 'robot' : 'plug' %>"></i>
            <strong><%= p.name %></strong>
            <% if (p.is_default) { %>
              <span class="pill green sm">Default</span>
            <% } %>
            <% if (!p.enabled) { %>
              <span class="pill gray sm">Disabled</span>
            <% } %>
            <% if (p.last_test_ok === 1) { %>
              <span class="pill blue sm"><i class="bi bi-check-circle"></i> Tested OK</span>
            <% } else if (p.last_test_ok === 0) { %>
              <span class="pill red sm"><i class="bi bi-x-circle"></i> Test failed</span>
            <% } %>
            <span class="cu-nav-count" style="margin-left: auto;">#<%= p.priority %></span>
          </div>
          <div class="panel-body" style="font-size: 13px;">
            <div style="display: grid; grid-template-columns: 110px 1fr; gap: 6px 12px;">
              <div class="text-muted">Kind</div>
              <div><code><%= p.kind %></code></div>
              <div class="text-muted">Model</div>
              <div><code><%= p.model || '—' %></code></div>
              <% if (p.base_url) { %>
                <div class="text-muted">Base URL</div>
                <div><code style="font-size: 11.5px;"><%= p.base_url %></code></div>
              <% } %>
              <div class="text-muted">API key</div>
              <div><code style="font-size: 11.5px;"><%= p.api_key_len ? '••••' + p.api_key_len + ' chars' : 'not set' %></code></div>
              <% if (p.notes) { %>
                <div class="text-muted">Notes</div>
                <div style="font-size: 12.5px; color: var(--text-2);"><%= p.notes %></div>
              <% } %>
            </div>

            <div style="margin-top: 14px; display: flex; gap: 6px; flex-wrap: wrap;">
              <form method="post" action="/admin/providers/<%= p.id %>/test" style="display: inline;">
                <button class="btn sm" type="submit"><i class="bi bi-broadcast"></i> Test connection</button>
              </form>
              <% if (!p.is_default) { %>
                <form method="post" action="/admin/providers/<%= p.id %>/default" style="display: inline;">
                  <button class="btn sm primary" type="submit"><i class="bi bi-star"></i> Set as default</button>
                </form>
              <% } %>
              <form method="post" action="/admin/providers/<%= p.id %>/toggle" style="display: inline;">
                <button class="btn sm" type="submit"><i class="bi bi-<%= p.enabled ? 'pause' : 'play' %>"></i> <%= p.enabled ? 'Disable' : 'Enable' %></button>
              </form>
              <a class="btn sm" href="/admin/providers/<%= p.id %>/edit"><i class="bi bi-pencil"></i> Edit</a>
              <form method="post" action="/admin/providers/<%= p.id %>/delete" style="display: inline;" onsubmit="return confirm('Delete this provider? Cached AI prep will fall back to structured-only.')">
                <button class="btn sm" style="color: var(--red);" type="submit"><i class="bi bi-trash"></i> Delete</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="panel">
      <div class="panel-head"><i class="bi bi-plus-circle"></i> Add provider</div>
      <div class="panel-body">
        <form method="post" action="/admin/providers">
          <div class="form-group mb-3">
            <label>Display name</label>
            <input name="name" required placeholder="e.g. OpenAI (primary)">
          </div>
          <div class="form-group mb-3">
            <label>Kind</label>
            <select name="kind" id="providerKind" onchange="updateKindDefaults()">
              <% kinds.forEach(k => { %>
                <option value="<%= k.kind %>" data-base="<%= k.defaultBaseUrl || '' %>" data-model="<%= k.defaultModel %>"><%= k.label %></option>
              <% }) %>
            </select>
            <small class="text-muted" style="font-size: 11.5px;">
              OpenAI = platform.openai.com. Anthropic = api.anthropic.com. OpenAI-compatible = Ollama, OpenRouter, Groq, Together, LM Studio, vLLM, Mistral, etc.
            </small>
          </div>
          <div class="form-group mb-3">
            <label>API key</label>
            <input name="api_key" type="password" placeholder="sk-... or sk-ant-..." autocomplete="off">
            <small class="text-muted" style="font-size: 11.5px;">Stored in plain text in SQLite (personal tool). Rotate if compromised.</small>
          </div>
          <div class="form-group mb-3" id="baseUrlGroup">
            <label>Base URL</label>
            <input name="base_url" id="baseUrl" placeholder="https://api.openai.com/v1">
            <small class="text-muted" style="font-size: 11.5px;">Only needed for OpenAI-compatible (Ollama, etc.).</small>
          </div>
          <div class="form-group mb-3">
            <label>Model</label>
            <input name="model" id="modelField" required placeholder="gpt-4o-mini">
            <small class="text-muted" style="font-size: 11.5px;" id="modelHint">
              For OpenAI: gpt-4o-mini, gpt-4o, o3-mini. Anthropic: claude-sonnet-4-5, claude-3-5-haiku-latest. OpenRouter: anthropic/claude-sonnet-4-5.
            </small>
          </div>
          <div class="form-group mb-3">
            <label>Priority <small class="text-muted">(lower = tried first)</small></label>
            <input name="priority" type="number" value="100" min="1" max="9999">
          </div>
          <div class="form-group mb-3">
            <label>
              <input type="checkbox" name="is_default" value="1" checked> Set as default
            </label>
          </div>
          <div class="form-group mb-3">
            <label>Notes <small class="text-muted">(optional)</small></label>
            <textarea name="notes" rows="2" placeholder="e.g. 'for cheap tagging', 'backup if OpenAI down'"></textarea>
          </div>
          <button class="btn primary" style="width: 100%;"><i class="bi bi-plus-lg"></i> Add provider</button>
        </form>
      </div>
    </div>
  </div>

</div>
</main>
</div>
<%- include('partials/foot') %>

<script>
function updateKindDefaults() {
  const sel = document.getElementById('providerKind');
  const opt = sel.options[sel.selectedIndex];
  const base = opt.getAttribute('data-base') || '';
  const model = opt.getAttribute('data-model') || '';
  document.getElementById('baseUrl').value = base;
  document.getElementById('modelField').value = model;
  document.getElementById('baseUrlGroup').style.display = sel.value === 'openai_compat' ? '' : 'none';
}
updateKindDefaults();
</script>
