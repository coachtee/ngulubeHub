<% const title = 'NgulubeHub — Dashboard'; const active = 'dashboard'; %>
<%- include('partials/head', { title, active }) %>
<div class="app-shell">
<%- include('partials/nav') %>

<main class="main">
<%- include('partials/topbar') %>

<div class="content">

  <!-- Page header (ClickUp-style) -->
  <div class="cu-page-head">
    <i class="bi bi-house-door"></i><span>Home</span>
    <i class="bi bi-chevron-right" style="font-size: 9px;"></i>
    <span>All Clients</span>
  </div>
  <header class="d-flex flex-wrap justify-between items-center mb-3" style="gap: 12px;">
    <div>
      <h1 class="cu-page-title"><i class="bi bi-people"></i> Business Clients</h1>
      <p class="cu-page-sub">Your growing network of <strong><%= stats.total %></strong> founders, advisors, and operators.</p>
    </div>
    <div class="cu-page-actions">
      <a class="btn" href="/join" target="_blank" rel="noopener"><i class="bi bi-link-45deg"></i> <span class="hidden-mobile">Share Join</span><span class="visible-mobile">Share</span></a>
      <a class="btn primary" href="/clients/new"><i class="bi bi-plus-lg"></i> <span class="hidden-mobile">Add Client</span><span class="visible-mobile">Add</span></a>
    </div>
  </header>

  <!-- Stats strip (ClickUp-style) -->
  <div class="stats">
    <div class="cu-stat">
      <span class="lbl">Total Clients</span>
      <span class="val"><%= stats.total %></span>
      <span class="delta">across <%= stats.sectors %> sectors</span>
    </div>
    <div class="cu-stat warn">
      <span class="lbl">Not Yet Contacted</span>
      <span class="val"><%= stats.notContacted %></span>
      <span class="delta"><a href="/pipeline/not-contacted">August targets →</a></span>
    </div>
    <div class="cu-stat good">
      <span class="lbl">In Motion</span>
      <span class="val"><%= stats.contacted %></span>
      <span class="delta up">↗ active conversations</span>
    </div>
    <div class="cu-stat" style="<%= stats.pending > 0 ? 'background: linear-gradient(180deg, #fffbeb 0%, var(--surface) 60%);' : '' %>">
      <span class="lbl">Pending Review</span>
      <span class="val" style="<%= stats.pending > 0 ? 'color: var(--yellow);' : '' %>"><%= stats.pending %></span>
      <span class="delta"><%- stats.pending > 0 ? '<a href="/dashboard?status=pending">Review now</a>' : 'no new submissions' %></span>
    </div>
  </div>

  <!-- Project + Task widgets (second row) -->
  <div class="stats" style="grid-template-columns: repeat(4, 1fr);">
    <div class="cu-stat">
      <span class="lbl">Active Projects</span>
      <span class="val"><%= projectStats.active %></span>
      <span class="delta"><a href="/projects">Open kanban →</a></span>
    </div>
    <div class="cu-stat warn">
      <span class="lbl">Overdue Tasks</span>
      <span class="val"><%= projectStats.overdueTasks %></span>
      <span class="delta"><a href="/tasks">My tasks →</a></span>
    </div>
    <div class="cu-stat">
      <span class="lbl">In Scoping</span>
      <span class="val"><%= projectStats.scoping %></span>
      <span class="delta"><%= projectStats.quoted %> quoted</span>
    </div>
    <div class="cu-stat good">
      <span class="lbl">Closed (Won)</span>
      <span class="val"><%= projectStats.closedWon %></span>
      <span class="delta">R <%= Number(projectStats.totalValue).toLocaleString() %> pipeline</span>
    </div>
  </div>

  <!-- TODAY widget — the morning dashboard view -->
  <div class="panel mb-3" style="border-left: 3px solid var(--accent);">
    <div class="panel-head">
      <i class="bi bi-sun"></i> Today — <%= new Date(todayData.today).toLocaleDateString('en-ZA', { weekday: 'long', day: 'numeric', month: 'long' }) %>
      <div class="right">
        <a class="btn ghost sm" href="/calendar">Full calendar →</a>
      </div>
    </div>
    <div class="panel-body" style="padding: 0;">
      <!-- Quick counts row -->
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border);">
        <div style="background: var(--surface); padding: 12px 16px; text-align: center;">
          <div style="font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 2px;">Overdue</div>
          <div style="font-size: 22px; font-weight: 700; color: <%= todayData.counts.overdueTasks > 0 ? 'var(--red)' : 'var(--text-3)' %>;"><%= todayData.counts.overdueTasks %></div>
          <div style="font-size: 10px; color: var(--text-3);">tasks</div>
        </div>
        <div style="background: var(--surface); padding: 12px 16px; text-align: center;">
          <div style="font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 2px;">Due today</div>
          <div style="font-size: 22px; font-weight: 700; color: <%= todayData.counts.dueTodayTasks > 0 ? 'var(--yellow)' : 'var(--text-3)' %>;"><%= todayData.counts.dueTodayTasks %></div>
          <div style="font-size: 10px; color: var(--text-3);">tasks</div>
        </div>
        <div style="background: var(--surface); padding: 12px 16px; text-align: center;">
          <div style="font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 2px;">Due this week</div>
          <div style="font-size: 22px; font-weight: 700; color: <%= todayData.counts.dueWeekTasks > 0 ? 'var(--blue)' : 'var(--text-3)' %>;"><%= todayData.counts.dueWeekTasks %></div>
          <div style="font-size: 10px; color: var(--text-3);">tasks</div>
        </div>
        <div style="background: var(--surface); padding: 12px 16px; text-align: center;">
          <div style="font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 2px;">Touches due</div>
          <div style="font-size: 22px; font-weight: 700; color: <%= todayData.counts.overdueTouches > 0 ? 'var(--red)' : todayData.counts.todayTouches > 0 ? 'var(--yellow)' : 'var(--text-3)' %>;"><%= todayData.counts.overdueTouches + todayData.counts.todayTouches %></div>
          <div style="font-size: 10px; color: var(--text-3);">overdue + today</div>
        </div>
      </div>

      <!-- List section: overdue + today + touches, side by side -->
      <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 1px; background: var(--border);">
        <!-- Left: task list -->
        <div style="background: var(--surface);">
          <% const allTasks = [...todayData.overdueTasks, ...todayData.dueToday, ...todayData.dueThisWeek]; %>
          <% if (allTasks.length === 0) { %>
            <div class="empty" style="padding: 24px 18px;">
              <i class="bi bi-check2-all"></i>
              <div class="t">Nothing due</div>
              <div class="s">No tasks overdue or due this week. 🎉</div>
            </div>
          <% } else { %>
            <% allTasks.slice(0, 5).forEach(t => {
                 const overdue = t.due_date < todayData.today;
                 const today = t.due_date === todayData.today;
            %>
              <a href="/projects/<%= t.project_id %>" class="my-task-row">
                <div class="mt-status">
                  <i class="bi bi-circle-fill" style="color: <%= overdue ? 'var(--red)' : today ? 'var(--yellow)' : 'var(--blue)' %>; font-size: 10px;"></i>
                </div>
                <div class="mt-body">
                  <div class="mt-title"><%= t.title %></div>
                  <div class="mt-meta">
                    <span><i class="bi bi-kanban"></i> <%= t.project_name %></span>
                    <% if (t.client_name) { %><span><i class="bi bi-person"></i> <%= t.client_name %></span><% } %>
                    <span><i class="bi bi-calendar"></i> <%= t.due_date %></span>
                  </div>
                </div>
                <% if (t.priority === 'urgent') { %>
                  <span class="pill red" style="font-size: 10px; padding: 1px 6px;"><span class="dot"></span>urgent</span>
                <% } else if (t.priority === 'high') { %>
                  <span class="pill orange" style="font-size: 10px; padding: 1px 6px;"><span class="dot"></span>high</span>
                <% } %>
              </a>
            <% }) %>
          <% } %>
        </div>
        <!-- Right: touches -->
        <div style="background: var(--surface);">
          <% if (todayData.upcomingTouches.length === 0) { %>
            <div class="empty" style="padding: 24px 18px;">
              <i class="bi bi-inbox"></i>
              <div class="t">No touches set</div>
              <div class="s">Set cadences on clients to populate this list.</div>
            </div>
          <% } else { %>
            <% todayData.upcomingTouches.forEach(t => { %>
              <a href="/clients/<%= t.client_id %>" class="my-task-row">
                <div class="mt-status">
                  <i class="bi bi-circle-fill" style="color: <%= t.is_overdue ? 'var(--red)' : t.days_until === 0 ? 'var(--yellow)' : 'var(--blue)' %>; font-size: 10px;"></i>
                </div>
                <div class="mt-body">
                  <div class="mt-title"><%= t.client_name %></div>
                  <div class="mt-meta">
                    <span><i class="bi bi-calendar"></i> <%= t.next_date %></span>
                    <% if (t.is_overdue) { %>
                      <span style="color: var(--red); font-weight: 500;"><%= Math.abs(t.days_until) %>d overdue</span>
                    <% } else if (t.days_until === 0) { %>
                      <span style="color: var(--yellow); font-weight: 500;">Today</span>
                    <% } else { %>
                      <span>in <%= t.days_until %>d</span>
                    <% } %>
                  </div>
                </div>
              </a>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Idea inbox + my upcoming tasks + active projects (three-up grid) -->
  <div class="dashboard-pm-grid">
    <!-- Idea inbox -->
    <div class="panel">
      <div class="panel-head">
        <i class="bi bi-lightbulb"></i> Idea Inbox
        <div class="right">
          <a class="btn ghost sm" href="/projects?view=list">All projects →</a>
        </div>
      </div>
      <div class="panel-body">
        <form method="POST" action="/ideas" class="idea-form">
          <input name="title" required maxlength="200" placeholder="Drop an idea — one line is enough…" style="flex: 1; height: 36px; padding: 0 12px; background: var(--bg); border: 1px solid var(--border); border-radius: 6px; color: var(--text); font-size: 13px;">
          <button type="submit" class="btn primary sm"><i class="bi bi-plus-lg"></i> Capture</button>
        </form>
        <% if (recentIdeas.length) { %>
          <div style="margin-top: 12px;">
            <% recentIdeas.forEach(i => { %>
              <a href="/projects/<%= i.id %>" class="idea-row">
                <i class="bi bi-lightbulb" style="color: var(--yellow);"></i>
                <span style="flex: 1;"><%= i.name %></span>
                <span class="text-muted" style="font-size: 11px;"><%= i.created_at.slice(0, 10) %></span>
              </a>
            <% }) %>
          </div>
        <% } else { %>
          <p class="text-muted mb-0" style="font-size: 12.5px; margin-top: 12px;">No ideas captured yet. Use this when something pops into your head — you can flesh it out later.</p>
        <% } %>
      </div>
    </div>

    <!-- My upcoming tasks -->
    <div class="panel">
      <div class="panel-head">
        <i class="bi bi-check2-square"></i> My Upcoming Tasks
        <div class="right">
          <a class="btn ghost sm" href="/tasks">All my tasks →</a>
        </div>
      </div>
      <div class="panel-body" style="padding: 0;">
        <% if (!myUpcomingTasks.length) { %>
          <div class="empty" style="padding: 24px 18px;">
            <i class="bi bi-check2-all" style="font-size: 28px;"></i>
            <div class="t">No upcoming tasks</div>
          </div>
        <% } %>
        <% myUpcomingTasks.forEach(t => { %>
          <a href="/projects/<%= t.project_id %>" class="my-task-row">
            <div class="mt-status"><i class="bi bi-circle-fill" style="color: <%= t.priority === 'urgent' ? 'var(--red)' : t.priority === 'high' ? 'var(--orange)' : 'var(--blue)' %>; font-size: 10px;"></i></div>
            <div class="mt-body">
              <div class="mt-title"><%= t.title %></div>
              <div class="mt-meta">
                <span><i class="bi bi-kanban"></i> <%= t.project_name %></span>
                <% if (t.client_name) { %><span><i class="bi bi-person"></i> <%= t.client_name %></span><% } %>
                <span><i class="bi bi-calendar"></i> <%= t.due_date %></span>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    </div>

    <!-- Active projects -->
    <div class="panel">
      <div class="panel-head">
        <i class="bi bi-kanban"></i> Active Work
        <div class="right">
          <a class="btn ghost sm" href="/projects">View all →</a>
        </div>
      </div>
      <div class="panel-body" style="padding: 0;">
        <% if (!activeProjects.length) { %>
          <div class="empty" style="padding: 24px 18px;">
            <i class="bi bi-inbox" style="font-size: 28px;"></i>
            <div class="t">No active projects</div>
            <div class="s">Capture an idea or <a href="/projects/new">create one</a>.</div>
          </div>
        <% } %>
        <% activeProjects.forEach(p => { %>
          <a href="/projects/<%= p.id %>" class="my-task-row">
            <div class="mt-status"><i class="bi bi-circle-fill" style="color: <%= p.status === 'active' ? 'var(--green)' : p.status === 'scoping' ? 'var(--yellow)' : 'var(--blue)' %>; font-size: 10px;"></i></div>
            <div class="mt-body">
              <div class="mt-title"><%= p.name %></div>
              <div class="mt-meta">
                <span class="pill <%= projects.PROJECT_STATUS_COLORS[p.status] %>" style="font-size: 10px; padding: 1px 6px;">
                  <span class="dot"></span><%= projects.PROJECT_STATUS_LABELS[p.status] %>
                </span>
                <% if (p.target_end_date) { %><span><i class="bi bi-calendar"></i> <%= p.target_end_date %></span><% } %>
                <% if (p.est_value_zar > 0) { %><span>R <%= Number(p.est_value_zar).toLocaleString() %></span><% } %>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- ClickUp-style client list -->
  <form class="cu-toolbar" method="get" action="/">
    <div class="cu-search">
      <i class="bi bi-search"></i>
      <input name="q" placeholder="Search by name, company, focus area, tag…" value="<%= q %>">
    </div>
    <select name="sector">
      <option value="">All sectors</option>
      <% sectors.forEach(s => { %>
        <option value="<%= s %>" <%= sector === s ? 'selected' : '' %>><%= s %></option>
      <% }) %>
    </select>
    <select name="status">
      <option value="">All statuses</option>
      <% ['not_contacted','intro_sent','engaged','won','pending'].forEach(st => { %>
        <option value="<%= st %>" <%= status === st ? 'selected' : '' %>><%= st.replace('_',' ') %></option>
      <% }) %>
    </select>
    <button class="btn" type="submit"><i class="bi bi-funnel"></i> Filter</button>
    <% if (q || sector || status) { %>
      <a class="btn ghost" href="/">Clear</a>
    <% } %>
    <div style="margin-left: auto; display: flex; gap: 8px;">
      <a class="btn sm" href="/api/clients.csv"><i class="bi bi-download"></i> Export</a>
    </div>
  </form>

  <!-- View switcher + count + add -->
  <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
    <div class="cu-views">
      <a class="active" href="/"><i class="bi bi-list-ul"></i> List <span class="cu-view-count"><%= clients.length %></span></a>
      <a href="/board"><i class="bi bi-kanban"></i> Board</a>
      <a href="/calendar"><i class="bi bi-calendar3"></i> Calendar</a>
    </div>
  </div>

  <!-- Compact list (clickup-style) -->
  <div class="table-card">
    <div class="cu-row-head">
      <div>Client</div>
      <div>Sector / Industry</div>
      <div>Status</div>
      <div>Focus</div>
      <div>Last Touch</div>
      <div style="text-align: right;">Solutions</div>
    </div>
    <% if (!clients.length) { %>
      <div class="cu-empty">
        <i class="bi bi-inbox"></i>
        <div class="t">No clients match your filters</div>
        <div class="s">Try clearing the filters or <a href="/clients/new">add a new client</a>.</div>
      </div>
    <% } %>
    <% clients.forEach(c => { %>
      <% const st = c.intro_status || 'not_contacted'; %>
      <a class="cu-row" href="/clients/<%= c.id %>">
        <div class="cu-cell">
          <div class="avatar-row">
            <div class="avatar"><%= (c.name||'?').split(' ').map(p=>p[0]).slice(0,2).join('').toUpperCase() %></div>
            <div class="meta">
              <div class="n cu-cell-truncate"><%= c.name %></div>
              <div class="s cu-cell-truncate"><%= c.company || c.title || '' %></div>
            </div>
          </div>
        </div>
        <div class="cu-cell">
          <div class="cu-cell-truncate"><%= c.sector || '—' %></div>
          <div class="cu-cell-sub cu-cell-truncate"><%= c.industry || '' %></div>
        </div>
        <div class="cu-cell">
          <span class="cu-status-dot <%= st %>"></span>
          <% if (st === 'engaged' || st === 'won') { %>
            <span class="pill green sm"><%= st === 'won' ? 'Won' : 'Engaged' %></span>
          <% } else if (st === 'intro_sent') { %>
            <span class="pill blue sm">Intro sent</span>
          <% } else if (st === 'pending') { %>
            <span class="pill yellow sm">Pending</span>
          <% } else { %>
            <span class="pill gray sm">Not contacted</span>
          <% } %>
        </div>
        <div class="cu-cell">
          <div class="cu-cell-tags">
            <% (c.focus_areas || []).slice(0, 2).forEach(f => { %>
              <span class="tag"><%= f %></span>
            <% }) %>
            <% if ((c.focus_areas||[]).length > 2) { %>
              <span class="tag more">+<%= c.focus_areas.length - 2 %></span>
            <% } %>
          </div>
        </div>
        <div class="cu-cell">
          <% if (c.last_contact_at) { %>
            <div class="cu-cell-truncate"><%= c.last_contact_at %></div>
          <% } else { %>
            <div class="cu-cell-sub">—</div>
          <% } %>
        </div>
        <div class="cu-cell" style="text-align: right;">
          <% const n = (c.ai_solutions||[]).length; %>
          <% if (n > 0) { %>
            <span class="pill purple sm"><i class="bi bi-stars"></i> <%= n %></span>
          <% } else { %>
            <span class="cu-cell-sub">—</span>
          <% } %>
        </div>
      </a>
    <% }) %>
  </div>

</div>
</main>
</div>
<%- include('partials/foot') %>
