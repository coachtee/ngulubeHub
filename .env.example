# Ngulube Hub — environment variables
# Copy this file to .env and fill in real values
# DO NOT COMMIT .env to git (it's in .gitignore)

# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# This is REQUIRED for sessions to work across server restarts
SESSION_SECRET=replace-me-with-64-hex-chars-from-crypto-randomBytes

# Optional
# NODE_ENV=production
# PORT=3000
